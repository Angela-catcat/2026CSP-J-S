省份：\rule[-3pt]{2.3cm}{0.4pt}\hfill 分赛区：\rule[-3pt]{2.3cm}{0.4pt}\hfill 学校：\rule[-3pt]{4.2cm}{0.4pt}\par
\vspace{0.7em}
姓名：\rule[-3pt]{4.2cm}{0.4pt}\hfill 性别：\rule[-3pt]{1.8cm}{0.4pt}\hfill 准考证号：\rule[-3pt]{3.8cm}{0.4pt}\par}
% 密封线
\vspace{0.6em}
\noindent\makebox[\textwidth]{\sealdash\hspace{1em}{\heiti 密}\hspace{0.7em}{\heiti 封}\hspace{0.7em}{\heiti 线}\hspace{1em}\sealdash}
\vspace{0.7em}
% 标题
\begin{center}
{\heiti\bfseries\large CCF 非专业级别软件能力认证第一轮}\\[0.4em]
